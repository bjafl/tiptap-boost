## Nøkkelmetoder

### 1. Dirty-tracking

Identifiser hvilke sider som ble påvirket av en transaksjon:

```ts
function markDirtyPages(tr: Transaction, pageMap: PageMap): Set<number> {
  const dirty = new Set<number>()

  tr.steps.forEach((step) => {
    const map = step.getMap()
    map.forEach((oldStart, oldEnd) => {
      for (const page of pageMap.pages) {
        if (oldStart < page.endPos && oldEnd > page.startPos) {
          dirty.add(page.pageIndex)
          if (page.pageIndex + 1 < pageMap.pages.length) {
            dirty.add(page.pageIndex + 1)
          }
        }
      }
    })
  })

  return dirty
}
```

### 2. Synkron overflow-estimering (appendTransaction)

Bruker høyde-cache i stedet for DOM-måling:

```ts
function estimatePageOverflow(
  doc: PMNode,
  page: { startPos: number; endPos: number },
  heightCache: HeightCache,
  pageContentHeight: number
): OverflowEstimate | null {
  let accumulated = 0
  let result: OverflowEstimate | null = null

  doc.nodesBetween(page.startPos, page.endPos, (node, pos) => {
    if (result) return false
    if (!node.isBlock) return

    const key = cacheKey(node)
    const height = heightCache.get(key) ?? fallbackHeight(node)
    accumulated += height

    if (accumulated > pageContentHeight) {
      result = {
        nodePos: pos,
        nodeType: node.type.name,
        remainingHeight: pageContentHeight - (accumulated - height),
        isEstimate: !heightCache.has(key),
      }
      return false
    }
  })

  return result
}

function fallbackHeight(node: PMNode): number {
  // Konservativt estimat når cache mangler
  if (node.type.name === 'paragraph') {
    const lineHeight = 24 // default, forbedres av cache
    const estimatedLines = Math.ceil(node.textContent.length / 80)
    return Math.max(estimatedLines, 1) * lineHeight
  }
  return 100 // grovt estimat for ukjente noder
}
```

### 3. DOM-basert overflow-deteksjon (view.update)

Verifiserer og korrigerer estimatet med faktisk DOM-måling:

```ts
function verifyAndCorrect(
  view: EditorView,
  pageMap: PageMap,
  heightCache: HeightCache
): Transaction | null {
  const { doc } = view.state
  let needsCorrection = false

  for (const pageIndex of pageMap.dirtyPages) {
    const page = pageMap.getPage(pageIndex)
    if (!page) continue

    // Mål og oppdater cache for alle noder på denne siden
    doc.nodesBetween(page.startPos, page.endPos, (node, pos) => {
      if (!node.isBlock) return
      const dom = view.nodeDOM(pos) as HTMLElement
      if (!dom) return

      const measured = dom.getBoundingClientRect().height
      const key = cacheKey(node)
      const cached = heightCache.get(key)

      heightCache.set(key, measured)

      if (cached !== undefined && Math.abs(cached - measured) > 1) {
        needsCorrection = true
      }
    })
  }

  if (needsCorrection) {
    // Dispatch korreksjon — trigger ny appendTransaction-runde
    const tr = view.state.tr.setMeta('paginationCorrection', true)
    tr.setMeta('addToHistory', false)
    return tr
  }

  return null
}
```

### 4. Blokk-nivå splitting

Når en hel blokk-node ikke passer, oppdaterer vi PageMap:

```ts
function splitAtBlock(pageMap: PageMap, overflowPageIndex: number, nodePos: number): PageMap {
  const page = pageMap.pages[overflowPageIndex]
  const updatedPage = { ...page, endPos: nodePos }

  const nextPage = pageMap.pages[overflowPageIndex + 1]
  if (nextPage) {
    nextPage.startPos = nodePos
  } else {
    pageMap.pages.push({
      startPos: nodePos,
      endPos: page.endPos,
      pageIndex: overflowPageIndex + 1,
    })
  }

  pageMap.pages[overflowPageIndex] = updatedPage
  return pageMap
}
```

### 5. Sub-paragraf splitting

Krever DOM-tilgang — kjøres i trinn 2 (view.update).
Bruker binærsøk med `Range.getBoundingClientRect()` for å finne
nøyaktig split-punkt. Håndterer mixed fonts, emoji, inline-noder
korrekt fordi vi måler det rendrede resultatet.

```ts
function splitParagraph(
  view: EditorView,
  parPos: number,
  remainingHeight: number
): Transaction | null {
  const { state } = view
  const { tr } = state
  const parNode = state.doc.nodeAt(parPos)

  // ── Guard: plass til minst 2 linjer (orphan-kontroll) ──
  const parDOM = view.nodeDOM(parPos) as HTMLElement
  const lineHeight = parseFloat(getComputedStyle(parDOM).lineHeight)
  if (remainingHeight < lineHeight * 2) return null

  // ── Finn DOM-grense ──
  const parRect = parDOM.getBoundingClientRect()
  const maxY = parRect.top + remainingHeight

  // ── TreeWalker over tekstnoder ──
  const walker = document.createTreeWalker(parDOM, NodeFilter.SHOW_TEXT)
  let splitTextNode: Text | null = null
  let splitCharOffset = 0

  while (walker.nextNode()) {
    const textNode = walker.currentNode as Text
    if (textNode.length === 0) continue

    const range = document.createRange()
    range.setStart(textNode, 0)
    range.setEnd(textNode, textNode.length)
    const textRect = range.getBoundingClientRect()

    if (textRect.bottom <= maxY) continue

    if (textRect.top >= maxY) {
      splitTextNode = textNode
      splitCharOffset = 0
      break
    }

    // ── Binærsøk: O(log n) getBoundingClientRect-kall ──
    let lo = 0
    let hi = textNode.length

    while (lo < hi) {
      const mid = (lo + hi) >>> 1
      range.setStart(textNode, 0)
      range.setEnd(textNode, mid)

      if (range.getBoundingClientRect().bottom <= maxY) {
        lo = mid + 1
      } else {
        hi = mid
      }
    }

    splitTextNode = textNode
    splitCharOffset = lo
    break
  }

  if (!splitTextNode) return null

  // ── Juster til ordgrense ──
  const text = splitTextNode.textContent!
  let adjusted = splitCharOffset
  while (adjusted > 0 && text[adjusted - 1] !== ' ') {
    adjusted--
  }
  if (adjusted === 0) adjusted = splitCharOffset

  // ── Widow-kontroll ──
  const totalLines = Math.round(parDOM.getBoundingClientRect().height / lineHeight)
  const headLines = Math.round(remainingHeight / lineHeight)
  const tailLines = totalLines - headLines
  if (tailLines < 2 && headLines > 2) {
    return splitParagraph(view, parPos, remainingHeight - lineHeight)
  }

  // ── Map til PM-posisjon og splitt ──
  const pmPos = view.posAtDOM(splitTextNode, adjusted)

  tr.split(pmPos)
  tr.setMeta('addToHistory', false)

  // ── Merk begge deler med splitId ──
  const splitId = crypto.randomUUID()
  const headPos = parPos
  const tailPos = tr.mapping.map(pmPos) + 1

  tr.setNodeMarkup(headPos, null, {
    ...parNode.attrs,
    splitId,
    splitPart: 'head',
  })

  tr.setNodeMarkup(tailPos, null, {
    ...parNode.attrs,
    splitId,
    splitPart: 'tail',
  })

  return tr
}
```

### 6. Multi-page paragraf

En paragraf lengre enn én side splittes rekursivt.
Eksisterende tail promoteres til mid:

```ts
function promoteTailToMid(tr: Transaction, existingTailPos: number): Transaction {
  const node = tr.doc.nodeAt(existingTailPos)!
  tr.setNodeMarkup(existingTailPos, null, {
    ...node.attrs,
    splitPart: 'mid',
  })
  return tr
}
```

Resultat over 4 sider:

```
Side 1:  { splitId: "abc", splitPart: "head" }
Side 2:  { splitId: "abc", splitPart: "mid"  }
Side 3:  { splitId: "abc", splitPart: "mid"  }
Side 4:  { splitId: "abc", splitPart: "tail" }
```

### 7. Fusjonering

Finner og joiner splittede noder som havnet på samme side:

```ts
function findFusionPairs(
  doc: PMNode,
  pageMap: PageMap
): Array<{ headPos: number; tailPos: number }> {
  const pairs: Array<{ headPos: number; tailPos: number }> = []
  const heads = new Map<string, { pos: number; pageIndex: number }>()

  doc.descendants((node, pos) => {
    if (!node.attrs.splitId) return

    const pageIndex = pageMap.pages.findIndex((p) => pos >= p.startPos && pos < p.endPos)

    if (node.attrs.splitPart === 'head' || node.attrs.splitPart === 'mid') {
      heads.set(`${node.attrs.splitId}:${pos}`, { pos, pageIndex })
    }

    if (node.attrs.splitPart === 'tail' || node.attrs.splitPart === 'mid') {
      for (const [key, head] of heads) {
        if (
          key.startsWith(node.attrs.splitId) &&
          head.pageIndex === pageIndex &&
          head.pos !== pos
        ) {
          pairs.push({ headPos: head.pos, tailPos: pos })
          break
        }
      }
    }
  })

  return pairs
}

function fusePair(tr: Transaction, headPos: number, tailPos: number): Transaction {
  const headNode = tr.doc.nodeAt(headPos)!
  const joinPos = headPos + headNode.nodeSize

  tr.join(joinPos)
  tr.setMeta('addToHistory', false)

  const fusedNode = tr.doc.nodeAt(headPos)!
  const hasMoreParts = nodeHasMoreSplitParts(tr.doc, fusedNode.attrs.splitId, headPos)

  if (!hasMoreParts) {
    tr.setNodeMarkup(headPos, null, {
      ...fusedNode.attrs,
      splitId: null,
      splitPart: null,
    })
  }

  return tr
}
```

### 8. Tabellsplitting med rowspan-sikkerhet

Tabeller splittes på rad-grense, aldri gjennom en celle med rowspan:

```ts
function findSafeTableSplitRow(
  view: EditorView,
  tablePos: number,
  tableNode: PMNode,
  remainingHeight: number
): number | null {
  const tableMap = TableMap.get(tableNode)
  const tableDOM = view.nodeDOM(tablePos) as HTMLElement
  const rows = tableDOM.querySelectorAll('tr')

  // Bygg set av utrygge rader (celle med rowspan krysser grensen)
  const unsafeRows = new Set<number>()

  for (let row = 0; row < tableMap.height; row++) {
    for (let col = 0; col < tableMap.width; col++) {
      const cellPos = tableMap.map[row * tableMap.width + col]
      const rect = tableMap.findCell(cellPos)
      if (rect.bottom > rect.top + 1) {
        for (let r = rect.top + 1; r < rect.bottom; r++) {
          unsafeRows.add(r)
        }
      }
    }
  }

  // Finn første trygge rad som overflower
  let accumulated = 0
  for (let i = 0; i < rows.length; i++) {
    accumulated += rows[i].getBoundingClientRect().height
    if (accumulated > remainingHeight) {
      for (let safe = i; safe >= 1; safe--) {
        if (!unsafeRows.has(safe)) return safe
      }
      return null // flytt hele tabellen
    }
  }

  return null // tabellen passer
}
```

### 9. Pull/push-korreksjon

```ts
function correctPageFill(
  view: EditorView,
  pageMap: PageMap,
  pageIndex: number
): 'overflow' | 'underflow' | 'ok' {
  const bodyEl = getPageBodyElement(view, pageIndex)
  const nextPage = pageMap.pages[pageIndex + 1]

  if (bodyEl.scrollHeight > bodyEl.clientHeight) {
    return 'overflow'
  }

  if (nextPage) {
    const availableSpace = bodyEl.clientHeight - bodyEl.scrollHeight
    const firstNodePos = nextPage.startPos
    const firstNodeDOM = view.nodeDOM(firstNodePos) as HTMLElement
    const firstNodeHeight = firstNodeDOM?.getBoundingClientRect().height ?? Infinity

    if (firstNodeHeight <= availableSpace) {
      return 'underflow'
    }
  }

  return 'ok'
}
```

### 10. Paste-håndtering

Batch-splitting i én transaksjon, bypass-er debounce:

```ts
function handlePaste(view: EditorView, tr: Transaction, pageMap: PageMap): Transaction {
  const pastePageIndex = pageMap.pages.findIndex(
    (p) => tr.selection.from >= p.startPos && tr.selection.from < p.endPos
  )

  let currentTr = tr
  let safety = 0
  const MAX_ITERATIONS = 50

  while (safety++ < MAX_ITERATIONS) {
    const overflow = findOverflowNode(view /* ... */)
    if (!overflow) break

    if (overflow.nodeType === 'paragraph') {
      const result = splitParagraph(view, overflow.nodePos, overflow.remainingHeight)
      if (result) currentTr = result
    } else {
      splitAtBlock(pageMap, pastePageIndex + safety, overflow.nodePos)
    }
  }

  currentTr.setMeta('addToHistory', false)
  return currentTr
}
```

