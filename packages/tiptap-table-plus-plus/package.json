{
  "name": "@tiptap-boost/tiptap-table-plus-plus",
  "version": "3.0.1",
  "description": "Tiptap table extension based on tiptap-table-plus, with added support for table borders and styling.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "watch": "tsc-watch --onSuccess \"echo 'Build completed'\"",
    "clean": "rimraf dist",
    "prebuild": "pnpm clean"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bjafl/tiptap-boost",
    "directory": "packages/tiptap-table-plus-plus"
  },
  "keywords": [
    "tiptap",
    "tiptap extension",
    "table",
    "pagination"
  ],
  "author": "Bjarte Lode",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bjafl/tiptap-boost/issues?labels=tiptap-table"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/pm": "^3.20.0"
  },
  "devDependencies": {
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@types/node": "^22.15.2",
    "css-property-parser": "^1.0.6",
    "tsc-watch": "^6.0.4",
    "typescript": "^5.8.3"
  }
}
