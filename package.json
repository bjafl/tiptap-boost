{
  "name": "tiptap-boost",
  "private": true,
  "version": "0.0.1",
  "description": "Tiptap extensions to boost the opensource tiptap experience.",
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "publish-packages": "changeset publish",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css}\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bjafl/tiptap-boost",
    "directory": "packages/tiptap-table-plus-plus"
  },
  "keywords": [
    "tiptap",
    "tiptap extension"
  ],
  "author": "Bjarte Lode",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bjafl/tiptap-boost/issues"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@vitest/coverage-v8": "^4.1.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
